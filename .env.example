# Portfólió Követő – környezeti változók
# Másold át .env névvel és töltsd ki.

# -------------------------------------------------------
# KÖTELEZŐ éles (production) használathoz
# -------------------------------------------------------

# Titkos kulcs a session-ökhöz
# Generálás: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ide-irj-egy-hosszu-veletlen-kulcsot

# Bejelentkezési adatok (admin user)
PORTFOLIO_USERNAME=admin
PORTFOLIO_PASSWORD=cserelesz-titkos-jelszora

# PostgreSQL kapcsolati URL (Vercel / production esetén kötelező)
# Példa: postgresql://user:password@host:5432/dbname
# DATABASE_URL=postgresql://...

# -------------------------------------------------------
# OPCIONÁLIS beállítások
# -------------------------------------------------------

# Alkalmazás környezet: local | production
# production módban DATABASE_URL kötelező, SQLite nem használható
APP_ENV=local
DATABASE_URL=postgresql://user:password@host:5432/dbname
ENABLE_DEFAULT_ADMIN=false
# Flask debug auto-reloader (local fejlesztésben általában false)
FLASK_USE_RELOADER=false

# Default admin letiltása (production deployment előtt: false)
# ENABLE_DEFAULT_ADMIN=false
